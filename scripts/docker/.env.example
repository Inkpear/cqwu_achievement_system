# ------------------------------
# Image tags
# ------------------------------
BACKEND_IMAGE=cqwu-achievement/backend:latest
FRONTEND_IMAGE=cqwu-achievement/frontend:latest

# Compose project name (container prefix). Keep stable to ensure --overwrite
# targets the same stack across repeated online/offline deployments.
COMPOSE_PROJECT_NAME=cqwu_achievement_system

# Container timezone. UTC+8 default. Use POSIX TZ to avoid tzdata dependency.
TZ=CST-8

# ------------------------------
# Exposed ports on host machine
# ------------------------------
FRONTEND_PORT=8080
BACKEND_PORT=8000
BACKEND_CONTAINER_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Nginx server_name for frontend container.
# Use your ops-assigned domain, e.g. achievements.example.com
NGINX_SERVER_NAME=_

# ------------------------------
# Backend environment behavior
# ------------------------------
APP_ENVIRONMENT=production
# External base URL used by backend-generated links/callbacks.
# Use your ops-assigned public backend URL.
APP_APPLICATION_BASE_URL=http://api.example.com
APP_JWT_SECRET=your-secret-key-change-this-in-production
APP_JWT_EXPIRATION=86400
APP_LOG_PATH=/tmp/logs
APP_LOG_PREFIX=achievement-api
APP_LOG_LEVEL=info

# ------------------------------
# Postgres
# ------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cqwu_achievement_database

# ------------------------------
# Redis
# ------------------------------
REDIS_PASSWORD=admin123

# ------------------------------
# MinIO / S3 compatible storage
# ------------------------------
# Must be an endpoint reachable by browser/client for presigned URL access.
# Example: http://your-public-minio-domain:9000
APP_STORAGE_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=admin123
S3_REGION=cn-north-1
S3_BUCKET_NAME=achievement-bucket
S3_SIG_EXP_SECONDS=1800
S3_VIEW_EXP_SECONDS=86400

# ------------------------------
# Deploy script bucket bootstrap
# ------------------------------
# scripts/docker/deploy.sh will create bucket automatically and add lifecycle
# rule for this prefix. Default: files under temp/ expire after 1 day.
# Endpoint used by deploy.sh when executing mc inside minio container.
# Keep localhost unless you have a custom in-container endpoint setup.
MINIO_BOOTSTRAP_ENDPOINT=http://127.0.0.1:9000
S3_TEMP_PREFIX=temp/
S3_TEMP_EXPIRE_DAYS=1
